{
  "name": "@openclaw/memory-milvus",
  "version": "2026.4.16",
  "description": "OpenClaw Milvus-backed long-term memory plugin with auto-recall/capture",
  "type": "module",
  "dependencies": {
    "@zilliz/milvus2-sdk-node": "^2.5.6",
    "typebox": "1.1.33",
    "openai": "^6.34.0"
  },
  "devDependencies": {
    "@openclaw/plugin-sdk": "workspace:*"
  },
  "openclaw": {
    "extensions": [
      "./index.ts"
    ],
    "install": {
      "npmSpec": "@openclaw/memory-milvus",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.4.10"
    },
    "compat": {
      "pluginApi": ">=2026.4.16"
    },
    "build": {
      "openclawVersion": "2026.4.16"
    },
    "release": {
      "publishToClawHub": true,
      "publishToNpm": true
    }
  }
}